{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
  },

  "include": ["./src"],
  "exclude": ["node_modules", "./dist"]
}
